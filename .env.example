# ---- Web Push (server) ----
# Generate a VAPID key pair once:  npx web-push generate-vapid-keys
# Put the PUBLIC key in BOTH places below (the NEXT_PUBLIC_ one is sent to the browser).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ---- Upstash Redis (server) — stores push subscriptions + scheduled reminders ----
# Create a free DB at https://console.upstash.com → copy the REST URL + TOKEN.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Cron protection ----
# Any long random string. The scheduler endpoint requires it.
CRON_SECRET=

# Note: the Gemini API key is NOT here — each user enters their own in the app
# (Settings), kept only in their browser.
